{
  "name": "joaf-viral-os",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "postinstall": "node -e \"const fs=require('fs'),https=require('https'),path=require('path');const dir=path.join(__dirname,'fonts');if(!fs.existsSync(dir))fs.mkdirSync(dir,{recursive:true});function dl(url,dest,cb){const f=fs.createWriteStream(dest);const get=(u)=>https.get(u,r=>{if(r.statusCode===301||r.statusCode===302)return get(r.headers.location);r.pipe(f);f.on('finish',()=>{f.close();cb&&cb();});}).on('error',e=>console.log('dl err:',e.message));get(url);}const b=path.join(dir,'NotoSansBengali-Bold.ttf');const r=path.join(dir,'NotoSansBengali-Regular.ttf');if(fs.existsSync(b)&&fs.existsSync(r)){console.log('fonts exist');process.exit(0);}dl('https://github.com/google/fonts/raw/main/ofl/notosansbengali/static/NotoSansBengali-Bold.ttf',b,()=>console.log('Bold downloaded'));dl('https://github.com/google/fonts/raw/main/ofl/notosansbengali/static/NotoSansBengali-Regular.ttf',r,()=>console.log('Regular downloaded'));\""
  },
  "dependencies": {
    "node-appwrite": "^14.0.0",
    "@resvg/resvg-js": "2.6.2"
  }
}

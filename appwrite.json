  "databases": [
    {
      "$id": "joaf",
      "name": "JOAF"
    }
  ],
  "collections": [
    {
      "$id": "admin_config",
      "name": "System Config",
      "enabled": true,
      "documentSecurity": false,
      "attributes": [
        {
          "key": "key",
          "type": "string",
          "size": 128,
          "required": true
        },
        {
          "key": "value",
          "type": "string",
          "size": 8192,
          "required": false
        },
        {
          "key": "updated_at",
          "type": "string",
          "size": 64,
          "required": false
        }
      ],
      "indexes": [
        {
          "key": "key_unique",
          "type": "unique",
          "attributes": [
            "key"
          ]
        }
      ],
      "permissions": [
        "create(\"any\")",
        "read(\"any\")",
        "update(\"any\")",
        "delete(\"any\")"
      ],
      "databaseId": "joaf"
    },
    {
      "$id": "push_subscriptions",
      "name": "Push Subscriptions",
      "enabled": true,
      "documentSecurity": false,
      "attributes": [
        {
          "key": "endpoint",
          "type": "string",
          "size": 2048,
          "required": true
        },
        {
          "key": "subscriptionJson",
          "type": "string",
          "size": 4096,
          "required": true
        },
        {
          "key": "district",
          "type": "string",
          "size": 255,
          "required": false
        },
        {
          "key": "active",
          "type": "boolean",
          "required": false,
          "default": true
        },
        {
          "key": "updatedAt",
          "type": "string",
          "size": 64,
          "required": false
        }
      ],
      "indexes": [
        {
          "key": "endpoint_unique",
          "type": "unique",
          "attributes": [
            "endpoint"
          ]
        },
        {
          "key": "active_idx",
          "type": "key",
          "attributes": [
            "active"
          ]
        }
      ],
      "permissions": [
        "create(\"any\")",
        "read(\"any\")",
        "update(\"any\")",
        "delete(\"any\")"
      ],
      "databaseId": "joaf"
    },
    {
      "$id": "notification_history",
      "name": "Notification History",
      "enabled": true,
      "documentSecurity": false,
      "attributes": [
        {
          "key": "type",
          "type": "string",
          "size": 64,
          "required": true
        },
        {
          "key": "title",
          "type": "string",
          "size": 512,
          "required": false
        },
        {
          "key": "body",
          "type": "string",
          "size": 1024,
          "required": false
        },
        {
          "key": "sentAt",
          "type": "string",
          "size": 64,
          "required": false
        },
        {
          "key": "totalSent",
          "type": "integer",
          "required": false,
          "default": 0
        },
        {
          "key": "totalFailed",
          "type": "integer",
          "required": false,
          "default": 0
        },
        {
          "key": "district",
          "type": "string",
          "size": 255,
          "required": false
        }
      ],
      "indexes": [
        {
          "key": "sentAt_idx",
          "type": "key",
          "attributes": [
            "sentAt"
          ]
        }
      ],
      "permissions": [
        "create(\"any\")",
        "read(\"any\")",
        "update(\"any\")",
        "delete(\"any\")"
      ],
      "databaseId": "joaf"
    },
    {
      "$id": "fb_queue",
      "name": "FB Queue",
      "enabled": true,
      "documentSecurity": false,
      "attributes": [
        {
          "key": "caption",
          "type": "string",
          "size": 8192,
          "required": false
        },
        {
          "key": "imageUrl",
          "type": "string",
          "size": 2048,
          "required": false
        },
        {
          "key": "videoUrl",
          "type": "string",
          "size": 2048,
          "required": false
        },
        {
          "key": "imageUrls",
          "type": "string",
          "size": 8192,
          "required": false
        },
        {
          "key": "action",
          "type": "string",
          "size": 64,
          "required": false,
          "default": "post"
        },
        {
          "key": "status",
          "type": "string",
          "size": 64,
          "required": false,
          "default": "pending"
        },
        {
          "key": "scheduled_at",
          "type": "string",
          "size": 64,
          "required": false
        },
        {
          "key": "pageIds",
          "type": "string",
          "size": 2048,
          "required": false
        },
        {
          "key": "locked_by",
          "type": "string",
          "size": 128,
          "required": false
        },
        {
          "key": "locked_at",
          "type": "string",
          "size": 64,
          "required": false
        },
        {
          "key": "result",
          "type": "string",
          "size": 4096,
          "required": false
        },
        {
          "key": "error",
          "type": "string",
          "size": 2048,
          "required": false
        },
        {
          "key": "createdAt",
          "type": "string",
          "size": 64,
          "required": false
        }
      ],
      "indexes": [
        {
          "key": "status_scheduled_idx",
          "type": "key",
          "attributes": [
            "status",
            "scheduled_at"
          ]
        }
      ],
      "permissions": [
        "create(\"any\")",
        "read(\"any\")",
        "update(\"any\")",
        "delete(\"any\")"
      ],
      "databaseId": "joaf"
    }

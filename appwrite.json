    "collections": [
        {
            "$id": "admin_config",
            "name": "System Config",
            "enabled": true,
            "documentSecurity": false,
            "attributes": [
                {
                    "key": "key",
                    "type": "string",
                    "size": 128,
                    "required": true
                },
                {
                    "key": "value",
                    "type": "string",
                    "size": 8192,
                    "required": false
                },
                {
                    "key": "updated_at",
                    "type": "string",
                    "size": 64,
                    "required": false
                }
            ],
            "indexes": [
                {
                    "key": "key_unique",
                    "type": "unique",
                    "attributes": [
                        "key"
                    ]
                }
            ],
            "permissions": [
                "create(\"any\")",
                "read(\"any\")",
                "update(\"any\")",
                "delete(\"any\")"
            ],
            "databaseId": "joaf"
        },
        {
            "$id": "push_subscriptions",
            "name": "Push Subscriptions",
            "enabled": true,
            "documentSecurity": false,
            "attributes": [
                {
                    "key": "endpoint",
                    "type": "string",

                    "key": "district",
                    "type": "string",
                    "size": 255,
                    "required": false
                },
                {
                    "key": "active",
                    "type": "boolean",
                    "required": false,
                    "default": true
                },
                {
                    "key": "updatedAt",
                    "type": "string",
                    "size": 64,
                    "required": false
                }
            ],
            "indexes": [
                {
                    "key": "endpoint_unique",
                    "type": "unique",
                    "attributes": [
                        "endpoint"
                    ]
                },
                {
                    "key": "active_idx",
                    "type": "key",
                    "attributes": [
                        "active"
                    ]
                }
            ],
            "permissions": [
                "create(\"any\")",
                "read(\"any\")",
                "update(\"any\")",
                "delete(\"any\")"
